{
  "name": "sweet-creative-inventory",
  "private": true,
  "version": "0.4.12",
  "description": "Inventory management for The Sweet Creative balloon boutique",
  "author": {
    "name": "The Sweet Creative",
    "email": "hello@thesweetcreative.com.au"
  },
  "homepage": "https://thesweetcreative.com.au",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run",
    "test:watch": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
